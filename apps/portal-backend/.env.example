NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
TRACKING_DEBUG_LOGS=0

# Producao: https://portal.advnoemia.com.br
# NEXT_PUBLIC_APP_URL=https://portal.advnoemia.com.br

# Site institucional (apex). Usado em links do portal + CORS das APIs publicas.
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://advnoemia.com.br

# Origens extra permitidas em CORS para POST /api/public/triage e /api/public/events.
# CORS_ALLOWED_ORIGINS=https://staging.advnoemia.com.br,http://127.0.0.1:5500

# Use the local API URL shown by `supabase start` or `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Use the local Publishable key shown by `supabase start` or `supabase status`.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=COLE_A_CHAVE_PUBLICA_LOCAL_DO_SUPABASE

# Use the local Secret key shown by `supabase start` or `supabase status`.
SUPABASE_SECRET_KEY=COLE_A_CHAVE_SECRETA_LOCAL_DO_SUPABASE

INVITE_REDIRECT_URL=http://127.0.0.1:3000/auth/callback
PASSWORD_RESET_REDIRECT_URL=http://127.0.0.1:3000/auth/callback

# =============================================================================
# NOTIFICACOES — DESENVOLVIMENTO LOCAL
# =============================================================================
# Usa o Inbucket local do Supabase (porta 54325).
# Nao precisa de dominio verificado nem conta externa.
# Para ver os e-mails capturados: http://localhost:54324
# =============================================================================
NOTIFICATIONS_PROVIDER=smtp
NOTIFICATIONS_WORKER_SECRET=dev-worker-secret-local-apenas
NOTIFICATIONS_SMTP_HOST=127.0.0.1
NOTIFICATIONS_SMTP_PORT=54325
NOTIFICATIONS_SMTP_SECURE=false
EMAIL_FROM=Noemia Paixao Advocacia <no-reply@advnoemia.local>
NOTIFICATIONS_REPLY_TO=contato@advnoemia.com.br
# CRON_SECRET nao e obrigatorio em dev. O endpoint /api/cron/notifications
# pode ser chamado manualmente via GET sem autenticacao quando CRON_SECRET
# nao estiver definido.

# =============================================================================
# NOTIFICACOES — PRODUCAO (configurar no painel do Vercel, nao aqui)
# =============================================================================
# 1. Crie uma conta em https://resend.com
# 2. Adicione e verifique o dominio advnoemia.com.br
# 3. Gere uma API key no painel do Resend
# 4. Configure as variaveis abaixo em: Vercel → Settings → Environment Variables
#
# NOTIFICATIONS_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=Noemia Paixao Advocacia <contato@advnoemia.com.br>
# NOTIFICATIONS_REPLY_TO=contato@advnoemia.com.br
#
# NOTIFICATIONS_WORKER_SECRET deve ser uma string aleatoria forte (min 12 chars).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NOTIFICATIONS_WORKER_SECRET=GERE_UM_SEGREDO_FORTE_AQUI
#
# CRON_SECRET protege o endpoint /api/cron/notifications contra chamadas externas.
# O Vercel injeta automaticamente este segredo nas chamadas do Cron Jobs.
# Configure o mesmo valor em: Vercel → Settings → Environment Variables
# CRON_SECRET=GERE_OUTRO_SEGREDO_FORTE_AQUI
# DEBUG_ROUTE_SECRET protege endpoints /api/debug e /api/test fora do localhost.
# Configure em homologacao/producao para liberar testes controlados sem expor diagnosticos publicamente.
# DEBUG_ROUTE_SECRET=GERE_UM_SEGREDO_FORTE_PARA_DEBUG
#
# RESEND_API_KEY nao e necessario para Resend em testes antes da verificacao de
# dominio. Enquanto o dominio nao esta verificado, use o remetente de teste do
# Resend: EMAIL_FROM=Teste <onboarding@resend.dev>
# =============================================================================

# =============================================================================
# IA — NOEMIA
# =============================================================================
# Gere uma chave em: https://platform.openai.com/api-keys
# Configure no painel do Vercel para producao.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4.1-mini
# =============================================================================

# =============================================================================
# MERCADO PAGO — SISTEMA DE PAGAMENTO
# =============================================================================
# 1. Crie uma conta em: https://www.mercadopago.com.br
# 2. Va para: Credenciais → Chaves de API → Copie Access Token
# 3. Configure no painel do Vercel para producao
#
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
# MERCADO_PAGO_WEBHOOK_SECRET=GERE_UM_SEGREDO_FORTE_PARA_WEBHOOK
# MERCADO_PAGO_WEBHOOK_ENFORCE_SIGNATURE=true
#
# Valor da consulta (opcional, padrao: 297.00)
# CONSULTATION_VALUE=297.00
#
# URL base da aplicacao (usada nos webhooks do Mercado Pago)
# NEXT_PUBLIC_BASE_URL=https://portal.advnoemia.com.br
# =============================================================================

# =============================================================================
# WEBHOOKS META / WHATSAPP — HARDENING DE ASSINATURA
# =============================================================================
# Em producao, a validacao de assinatura passa a ser fail-closed por padrao.
# Em dev/homologacao, voce pode ativar o mesmo comportamento explicitamente:
#
# META_WEBHOOK_ENFORCE_SIGNATURE=true
# WHATSAPP_WEBHOOK_ENFORCE_SIGNATURE=true
#
# WhatsApp Cloud API:
# Você pode configurar com os nomes legados do webhook ou com os nomes oficiais META_*.
# O webhook inbound aceita ambos para evitar quebra operacional:
# WHATSAPP_APP_SECRET=SEU_APP_SECRET_META
# META_APP_SECRET=SEU_APP_SECRET_META
# WHATSAPP_ACCESS_TOKEN=EAA...
# META_WHATSAPP_ACCESS_TOKEN=EAA...
# WHATSAPP_PHONE_NUMBER_ID=1234567890
# META_WHATSAPP_PHONE_NUMBER_ID=1234567890
# WHATSAPP_VERIFY_TOKEN=SEU_VERIFY_TOKEN
# =============================================================================

PORTAL_ADMIN_EMAIL=advogada@advnoemia.local
PORTAL_ADMIN_FULL_NAME=Noemia Paixao
PORTAL_ADMIN_TEMP_PASSWORD=TroqueEstaSenha123
