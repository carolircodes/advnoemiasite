NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
TRACKING_DEBUG_LOGS=0

# Nunca versionar segredos reais, tokens, dumps, exports, backups, logs,
# uploads ou JSONs de diagnostico/checkout. Use este arquivo apenas como
# template seguro para configuracao local e deploy.

# Producao: https://portal.advnoemia.com.br
# NEXT_PUBLIC_APP_URL=https://portal.advnoemia.com.br

# Site institucional (apex). Usado em links do portal + CORS das APIs publicas.
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://advnoemia.com.br

# Origens extra permitidas em CORS para POST /api/public/triage e /api/public/events.
# CORS_ALLOWED_ORIGINS=https://staging.advnoemia.com.br,http://127.0.0.1:5500

# Use the local API URL shown by `supabase start` or `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Use the local Publishable key shown by `supabase start` or `supabase status`.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=COLE_A_CHAVE_PUBLICA_LOCAL_DO_SUPABASE

# Use the local Secret key shown by `supabase start` or `supabase status`.
SUPABASE_SECRET_KEY=COLE_A_CHAVE_SECRETA_LOCAL_DO_SUPABASE

INVITE_REDIRECT_URL=http://127.0.0.1:3000/auth/callback
PASSWORD_RESET_REDIRECT_URL=http://127.0.0.1:3000/auth/callback

# =============================================================================
# NOTIFICACOES - DESENVOLVIMENTO LOCAL
# =============================================================================
# Usa o Inbucket local do Supabase (porta 54325).
# Para ver os e-mails capturados: http://localhost:54324
# =============================================================================
NOTIFICATIONS_PROVIDER=smtp
NOTIFICATIONS_WORKER_SECRET=dev-worker-secret-local-apenas
NOTIFICATIONS_SMTP_HOST=127.0.0.1
NOTIFICATIONS_SMTP_PORT=54325
NOTIFICATIONS_SMTP_SECURE=false
EMAIL_FROM=Noemia Paixao Advocacia <no-reply@advnoemia.local>
NOTIFICATIONS_REPLY_TO=contato@advnoemia.com.br
# Em desenvolvimento local, /api/cron/notifications aceita fallback sem
# segredo apenas em localhost. Em deploy, configure CRON_SECRET obrigatoriamente.

# =============================================================================
# NOTIFICACOES - PRODUCAO (configurar no painel do Vercel, nao aqui)
# =============================================================================
# NOTIFICATIONS_PROVIDER=resend
# RESEND_API_KEY=<configure_no_painel>
# EMAIL_FROM=Noemia Paixao Advocacia <contato@advnoemia.com.br>
# NOTIFICATIONS_REPLY_TO=contato@advnoemia.com.br
#
# NOTIFICATIONS_WORKER_SECRET deve ser uma string aleatoria forte.
# CRON_SECRET protege o endpoint /api/cron/notifications.
# INTERNAL_API_SECRET protege rotas internas sem sessao de usuario.
# SITE_CHAT_SESSION_SECRET assina a sessao httpOnly do chat publico.
# DEBUG_ROUTE_SECRET protege endpoints /api/debug e /api/test fora do localhost.
#
# Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# NOTIFICATIONS_WORKER_SECRET=GERE_UM_SEGREDO_FORTE_AQUI
# CRON_SECRET=GERE_OUTRO_SEGREDO_FORTE_AQUI
# INTERNAL_API_SECRET=GERE_UM_SEGREDO_FORTE_PARA_ROTAS_INTERNAS
# NEXT_PUBLIC_PUSH_VAPID_PUBLIC_KEY=CHAVE_PUBLICA_VAPID_DO_PILOTO_PUSH
# PUSH_VAPID_PRIVATE_KEY=CHAVE_PRIVADA_VAPID_DO_PILOTO_PUSH
# NOTIFICATIONS_PUSH_PILOT_ENABLED=false
# SITE_CHAT_SESSION_SECRET=GERE_UM_SEGREDO_FORTE_PARA_O_CHAT_PUBLICO
# DEBUG_ROUTE_SECRET=GERE_UM_SEGREDO_FORTE_PARA_DEBUG
# =============================================================================

# =============================================================================
# IA - NOEMIA
# =============================================================================
# OPENAI_API_KEY=<configure_no_painel>
# OPENAI_MODEL=gpt-4.1-mini
# =============================================================================

# =============================================================================
# TELEGRAM - WEBHOOK E DISTRIBUICAO
# =============================================================================
# TELEGRAM_BOT_TOKEN=<configure_no_painel>
# TELEGRAM_WEBHOOK_SECRET=<configure_no_painel>
# TELEGRAM_CHANNEL_USERNAME=advnoemia
# TELEGRAM_CHANNEL_URL=https://t.me/advnoemia
# TELEGRAM_CURATED_GROUP_ID=-1001234567890
# TELEGRAM_CURATED_GROUP_TITLE=Comunidade Curada AdvNoemia
# =============================================================================

# =============================================================================
# MERCADO PAGO - SISTEMA DE PAGAMENTO
# =============================================================================
# MERCADO_PAGO_ACCESS_TOKEN=<configure_no_painel>
# MERCADO_PAGO_WEBHOOK_SECRET=<configure_no_painel>
# MERCADO_PAGO_WEBHOOK_ENFORCE_SIGNATURE=true
#
# Em deploy, POST /api/payment/create exige INTERNAL_API_SECRET ou sessao staff.
# GET /api/payment/webhook exige acesso interno/staff para diagnostico.
#
# Valor da consulta (opcional, padrao: 297.00)
# CONSULTATION_VALUE=297.00
#
# URL base da aplicacao (usada nos webhooks do Mercado Pago)
# NEXT_PUBLIC_BASE_URL=https://portal.advnoemia.com.br
# =============================================================================

# =============================================================================
# PROTECAO DURAVEL
# =============================================================================
# Em producao, memory fallback de rate limit/idempotencia agora bloqueia
# rotas criticas. Use apenas para explicitar a politica em ambiente controlado.
# DURABLE_PROTECTION_REQUIRED=true
# =============================================================================

# =============================================================================
# ASSINATURAS / RECORRENCIA PREMIUM
# =============================================================================
# ECOSYSTEM_SUBSCRIPTION_WEBHOOK_SECRET=GERE_UM_SEGREDO_FORTE_PARA_A_RECORRENCIA
# =============================================================================

# =============================================================================
# WEBHOOKS META / WHATSAPP - HARDENING DE ASSINATURA
# =============================================================================
# META_WEBHOOK_ENFORCE_SIGNATURE=true
# WHATSAPP_WEBHOOK_ENFORCE_SIGNATURE=true
#
# Os nomes legados continuam aceitos para evitar quebra operacional:
# WHATSAPP_APP_SECRET=<configure_no_painel>
# META_APP_SECRET=<configure_no_painel>
# WHATSAPP_ACCESS_TOKEN=<configure_no_painel>
# META_WHATSAPP_ACCESS_TOKEN=<configure_no_painel>
# WHATSAPP_PHONE_NUMBER_ID=<configure_no_painel>
# META_WHATSAPP_PHONE_NUMBER_ID=<configure_no_painel>
# WHATSAPP_VERIFY_TOKEN=<configure_no_painel>
# =============================================================================

PORTAL_ADMIN_EMAIL=advogada@advnoemia.local
PORTAL_ADMIN_FULL_NAME=Noemia Paixao
PORTAL_ADMIN_TEMP_PASSWORD=TroqueEstaSenha123
