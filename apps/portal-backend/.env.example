NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Produção (portal): https://portal.advnoemia.com.br
# NEXT_PUBLIC_APP_URL=https://portal.advnoemia.com.br

# Site institucional (apex). Usado em links do portal + CORS das APIs públicas.
# NEXT_PUBLIC_PUBLIC_SITE_URL=https://advnoemia.com.br

# Origens extra permitidas em CORS para POST /api/public/triage e /api/public/events (opcional).
# CORS_ALLOWED_ORIGINS=https://staging.advnoemia.com.br,http://127.0.0.1:5500

# Use the local API URL shown by `supabase start` or `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Use the local Publishable key shown by `supabase start` or `supabase status`.
