# Configurações da Meta para Webhook e WhatsApp Business
META_APP_SECRET=your_meta_app_secret_here
META_VERIFY_TOKEN=your_webhook_verify_token_here

# WhatsApp Business API
META_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Configurações do Instagram
META_INSTAGRAM_APP_ID=your_instagram_app_id_here
META_INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
META_INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Analytics e Tracking (opcional)
META_ANALYTICS_WEBHOOK=https://your-analytics-service.com/webhook
META_ANALYTICS_TOKEN=your_analytics_token_here

# Configurações de Desenvolvimento
NODE_ENV=development
DEBUG_META=true
