# CRON/NOTIFICACOES - Configuracao Obrigatoria
EMAIL_FROM=contato@advnoemia.com.br

# PROVIDER RESEND (Recomendado)
NOTIFICATIONS_PROVIDER=resend
RESEND_API_KEY=re_ExampleKey_ReplaceWithRealKey

# PROVIDER SMTP (Fallback - Alternativa)
# NOTIFICATIONS_PROVIDER=smtp
# NOTIFICATIONS_SMTP_HOST=smtp.gmail.com
# NOTIFICATIONS_SMTP_PORT=587
# NOTIFICATIONS_SMTP_USER=seu_email@gmail.com
# NOTIFICATIONS_SMTP_PASS=sua_senha_app
# NOTIFICATIONS_SMTP_SECURE=true

# EMAIL REPLICA (Opcional)
NOTIFICATIONS_REPLY_TO=contato@advnoemia.com.br

# SEGREDOS DE OPERACAO
CRON_SECRET=cron_secret_2026_advnoemia_portal
INTERNAL_API_SECRET=replace_with_strong_internal_api_secret
SITE_CHAT_SESSION_SECRET=replace_with_strong_site_chat_secret
MERCADO_PAGO_WEBHOOK_SECRET=replace_with_strong_mercado_pago_webhook_secret
DURABLE_PROTECTION_REQUIRED=true
