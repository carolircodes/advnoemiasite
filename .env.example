# Sistema Híbrido OpenAI + Fallback - Variáveis de Ambiente
# Copie este arquivo para .env.local (desenvolvimento) ou configure no seu serviço de produção

# =============================================================================
# 🔧 CONFIGURAÇÃO DO SISTEMA HÍBRIDO
# =============================================================================

# OpenAI (OPCIONAL - sistema funciona sem OpenAI)
ENABLE_OPENAI=false                    # true=usar IA quando disponível, false=só fallback
OPENAI_API_KEY=                       # Chave da OpenAI (só se ENABLE_OPENAI=true)
OPENAI_MODEL=gpt-4o-mini             # Modelo da OpenAI

# =============================================================================
# 📷 INSTAGRAM CONFIGURAÇÃO
# =============================================================================

# Meta Verify Token (webhook verification)
META_VERIFY_TOKEN=your_meta_verify_token

# Meta App Secret (signature validation)
META_APP_SECRET=your_meta_app_secret

# Facebook/Messenger App Secret (optional dedicated signature validation for object=page)
FACEBOOK_APP_SECRET=

# Instagram-specific App Secret (optional legacy compatibility)
INSTAGRAM_APP_SECRET=

# Legacy Meta Instagram App Secret (optional compatibility only)
META_INSTAGRAM_APP_SECRET=

# Instagram Access Token (enviar mensagens)
INSTAGRAM_ACCESS_TOKEN=

# =============================================================================
# 💬 WHATSAPP CONFIGURAÇÃO
# =============================================================================

# WhatsApp Verify Token (webhook verification)
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

# WhatsApp App Secret (signature validation)
WHATSAPP_APP_SECRET=your_whatsapp_app_secret

# WhatsApp Access Token (enviar mensagens)
WHATSAPP_ACCESS_TOKEN=

# WhatsApp Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# =============================================================================
# 🗄️ SUPABASE CONFIGURAÇÃO
# =============================================================================

# URL do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (acesso total ao banco)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# 🌐 SITE CONFIGURAÇÃO
# =============================================================================

# URL pública do site
NEXT_PUBLIC_PUBLIC_SITE_URL=https://advnoemia.com.br

# WhatsApp da advogada
NOEMIA_WHATSAPP_URL=https://wa.me/5511999999999

# =============================================================================
# ⚙️ FEATURES CONFIGURAÇÃO
# =============================================================================

# Auto-responder a comentários do Instagram
ENABLE_COMMENT_AUTOREPLY=true

# Validar assinatura HMAC dos webhooks (recomendado em produção)
ENABLE_SIGNATURE_VALIDATION=true

# =============================================================================
# 🚀 EXEMPLOS DE CONFIGURAÇÃO
# =============================================================================

# ======== DESENVOLVIMENTO (SEM OPENAI) ========
# ENABLE_OPENAI=false
# ENABLE_SIGNATURE_VALIDATION=false
# (outras variáveis com valores de teste)

# ======== DESENVOLVIMENTO (COM OPENAI) ========
# ENABLE_OPENAI=true
# OPENAI_API_KEY=<configure_if_enabled>
# OPENAI_MODEL=gpt-4o-mini

# ======== PRODUÇÃO (OPENAI HABILITADA) ========
# ENABLE_OPENAI=true
# OPENAI_API_KEY=<configure_if_enabled>
# OPENAI_MODEL=gpt-4o-mini
# ENABLE_SIGNATURE_VALIDATION=true

# ======== PRODUÇÃO (SÓ FALLBACK) ========
# ENABLE_OPENAI=false
# ENABLE_SIGNATURE_VALIDATION=true

# =============================================================================
# 📝 INSTRUÇÕES
# =============================================================================

# 1. Copie este arquivo para .env.local (desenvolvimento)
# 2. Ajuste os valores conforme seu ambiente
# 3. Em produção, configure as variáveis diretamente no painel (Vercel/Render)
# 4. Teste com: node test_hybrid_system.js
# 5. Monitore os logs para verificar o comportamento

# =============================================================================
# 🔍 COMO TESTAR
# =============================================================================

# Teste 1: Sem OpenAI
# ENABLE_OPENAI=false
# → Deve ver log: 🚫 OPENAI_DISABLED
# → Deve receber resposta de fallback

# Teste 2: Com OpenAI mas sem API key
# ENABLE_OPENAI=true
# (sem OPENAI_API_KEY)
# → Deve ver log: 🚫 OPENAI_SKIPPED
# → Deve receber resposta de fallback

# Teste 3: Com OpenAI funcionando
# ENABLE_OPENAI=true
# OPENAI_API_KEY=sk-key-valida
# → Deve ver log: ✅ OPENAI_ENABLED
# → Deve receber resposta da IA

# Teste 4: Com OpenAI com erro
# ENABLE_OPENAI=true
# OPENAI_API_KEY=sk-key-invalida
# → Deve ver log: 🛡️ OPENAI_FAILED_FALLBACK_USED
# → Deve receber resposta de fallback

# =============================================================================
# 📚 REFERÊNCIA
# =============================================================================

# Documentação completa: HYBRID_OPENAI_SETUP.md
# Script de teste: test_hybrid_system.js
# Suporte: Verificar logs com emojis para debug
# =============================================================================
# PHASE 12 - OMNICHANNEL ORCHESTRATION
# =============================================================================

CHANNEL_ENABLE_PHASE12_JOURNEY_ORCHESTRATION=true
CHANNEL_ENABLE_PHASE12_EXECUTIVE_DASHBOARD=true
CHANNEL_ENABLE_PHASE12_EXTERNAL_DISPATCH_PREPARATION=true

# =============================================================================
# YOUTUBE - OMNICHANNEL OPERATIONS
# =============================================================================

YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_REDIRECT_URI=
YOUTUBE_WEBHOOK_CALLBACK_URL=
YOUTUBE_OAUTH_STATE_SECRET=
YOUTUBE_MODE=read_only
YOUTUBE_REPLY_ENABLED=false
YOUTUBE_AUTO_REPLY_ENABLED=false
YOUTUBE_ENABLE_INGESTION=false
YOUTUBE_ENABLE_COMMENT_SYNC=false
YOUTUBE_ENABLE_COMMENT_READ_ONLY=true
YOUTUBE_ENABLE_COMMENT_SUGGESTION_MODE=true
YOUTUBE_ENABLE_COMMENT_ACTIVE_REPLY=false
YOUTUBE_ENABLE_INBOX_ROUTING=true
YOUTUBE_ENABLE_CRM_ROUTING=true
YOUTUBE_ENABLE_HUMAN_REVIEW_DEFAULT=true
YOUTUBE_COMMENT_COOLDOWN_MINUTES=180
YOUTUBE_MAX_REPLIES_PER_AUTHOR_WINDOW=3
YOUTUBE_MAX_REPLIES_PER_ASSET_WINDOW=60
YOUTUBE_COMMENT_MAX_REPLIES_PER_WINDOW=3
YOUTUBE_COMMENT_AUTHOR_COOLDOWN_MINUTES=180
YOUTUBE_COMMENT_VIDEO_COOLDOWN_MINUTES=60
