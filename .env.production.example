# Production deployment example
# Configure real values in Vercel or your deployment provider.
# Do not commit populated environment files.

# Canonical portal host
NEXT_PUBLIC_APP_URL=https://portal.example.com
NEXT_PUBLIC_PUBLIC_SITE_URL=https://portal.example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<configure_in_provider>
SUPABASE_SECRET_KEY=<configure_in_provider>

# Internal perimeter
INTERNAL_API_SECRET=<configure_in_provider>
NOTIFICATIONS_WORKER_SECRET=<configure_in_provider>
CRON_SECRET=<configure_in_provider>

# Notifications
NOTIFICATIONS_PROVIDER=resend
EMAIL_FROM=ops@example.com
RESEND_API_KEY=<configure_in_provider>

# Payments
MERCADO_PAGO_ACCESS_TOKEN=<configure_in_provider>
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=<configure_in_provider>
MERCADO_PAGO_WEBHOOK_SECRET=<configure_in_provider>
MERCADO_PAGO_WEBHOOK_ENFORCE_SIGNATURE=true

# Telegram
TELEGRAM_BOT_TOKEN=<configure_in_provider>
TELEGRAM_WEBHOOK_SECRET=<configure_in_provider>

# Meta / WhatsApp
META_VERIFY_TOKEN=<configure_in_provider>
META_APP_SECRET=<configure_in_provider>
FACEBOOK_APP_SECRET=<configure_in_provider>
FACEBOOK_PAGE_ACCESS_TOKEN=<configure_in_provider>
WHATSAPP_VERIFY_TOKEN=<configure_in_provider>
WHATSAPP_APP_SECRET=<configure_in_provider>
WHATSAPP_ACCESS_TOKEN=<configure_in_provider>
WHATSAPP_PHONE_NUMBER_ID=<configure_in_provider>

# OpenAI / Noemia
ENABLE_OPENAI=false
OPENAI_API_KEY=<configure_in_provider>
OPENAI_MODEL=gpt-5.4
